#!/bin/sh
# autoconf — drop-in wrapper for autoconf-rs (NC.PERM.1 resolution)
#
# This script provides a GNU Autoconf-compatible interface to autoconf-rs.
# Place this in PATH as 'autoconf' to use autoconf-rs as a drop-in replacement.
#
# Usage: autoconf [OPTIONS] [TEMPLATE-FILE]
#
# Supported GNU Autoconf flags:
#   -h, --help          Display help
#   -V, --version       Display version
#   -v, --verbose       Verbose output
#   -d, --debug         Debug mode
#   -f, --force         Force overwrite
#   -o, --output=FILE   Output file
#   -I, --include=DIR   Add include directory
#   -B, --prepend-include=DIR  Prepend include directory
#   -W, --warnings=CAT  Warning category
#   --trace=MACRO       Trace macro expansion
#   --initialization    Enable full M4 initialization
#
# Court: NC.PERM.1 RESOLUTION
# Receipt: AC.CLI.DROPIN.1

set -e

# Find the autoconf-rs binary
AUTOCONF_RS="${AUTOCONF_RS_BIN:-autoconf-rs}"
if ! command -v "$AUTOCONF_RS" >/dev/null 2>&1; then
    echo "autoconf: autoconf-rs binary not found (tried: $AUTOCONF_RS)" >&2
    echo "autoconf: set AUTOCONF_RS_BIN environment variable to the binary path" >&2
    exit 1
fi

# Handle GNU-style --version / --help directly
case "${1:-}" in
    --version|-V)
        exec "$AUTOCONF_RS" --version
        ;;
    --help|-h)
        exec "$AUTOCONF_RS" --help
        ;;
esac

# Forward all arguments to autoconf-rs with compatibility mode
exec "$AUTOCONF_RS" --compat "$@"
